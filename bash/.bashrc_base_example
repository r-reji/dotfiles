#===================
# ADD TO START OF LOCAL .bashrc
#===================
# ===================
# Base shell check
# ===================

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# ===================
# Load Configs & Aliases
# ===================

# Secrets
if [ -f ~/.secrets ]; then
    . ~/.secrets
fi

# Shared Bash Config
if [ -f ~/.bashrc_shared ]; then
    . ~/.bashrc_shared
fi

# Shared Aliases
if [ -f ~/.bash_aliases_shared ]; then
    . ~/.bash_aliases_shared
fi

# Local Aliases (overrides shared aliases if there are any conflicts)
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# ===================
# Tmux Lite Aliases (copy for ssh)
# ===================
alias mytmux="tmux -S /tmp/tmux_rreji -f ~/.tmux.rreji.conf new-session -A -s main"
alias myattach="tmux -S /tmp/tmux_rreji attach -t main"
