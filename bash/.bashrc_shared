# ===================
# History
# ===================
HISTCONTROL=ignoreboth
shopt -s histappend
HISTSIZE=100000
HISTFILESIZE=100000
HISTTIMEFORMAT="%F %T "

# ===================
# Shell Options
# ===================
# Check the window size after each command
shopt -s checkwinsize
# Allow ** to recursively match all directories
# shopt -s globstar
# Disable terminal flow control
stty -ixon
# Make less more friendly for non-text input files
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# ===================
# Colors & Aliases
# ===================
# Enable color support of ls and basic grep
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# ===================
# Autocompletion
# ===================
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# ===================
# WSL Compatibility
# ===================
if grep -qi microsoft /proc/version 2>/dev/null; then
    export IS_WSL=1
fi

if [ "$IS_WSL" = "1" ]; then
    # WSL configs
    :
fi

# ===================
# FZF Integration
# ===================
if [ -f ~/.fzf.bash ]; then
    source ~/.fzf.bash
fi

[ -f /usr/share/doc/fzf/examples/key-bindings.bash ] && source /usr/share/doc/fzf/examples/key-bindings.bash
[ -f /usr/share/doc/fzf/examples/completion.bash ] && source /usr/share/doc/fzf/examples/completion.bash

export FZF_DEFAULT_COMMAND='fdfind --strip-cwd-prefix --hidden --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fdfind --type d --strip-cwd-prefix --hidden --exclude .git'
export FZF_CTRL_T_OPTS="--preview 'batcat --style=numbers --color=always --line-range :500 {}' --preview-window=right:60%"

# Launch tmux from fzf, absolute path as $PATH sometimes gets weird
if [[ -z "$TMUX" ]]; then
    bind -x '"\C-f": "$HOME/.local/bin/tmux-sessionizer"'
fi

# ===================
# Keybindings
# ===================
# Enable vi mode for the bash command line
set -o vi

# ===================
# Directory Cache Warmer (for sessionizer)
# ===================
(fdfind --hidden --type d '^.git$' ~ > /dev/null 2>&1 &)

# ===================
# Starship
# ===================
eval "$(starship init bash)"

# ===================
# Auto-start Tmux (Continuum)
# ===================
if [[ $- =~ i ]] && [[ -z "$TMUX" ]]; then
    # Create or attach to a session named "main".
    tmux new-session -A -s "main"
fi

# ===================
# Path + Cleanup
# ===================
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Keeps the first occurrence of each directory
# Artifact from nesting bash shells with tmux
# if [ -n "$PATH" ]; then
#     export PATH=$(echo "$PATH" | tr ':' '\n' | awk '!x[$0]++' | tr '\n' ':' | sed 's/:$//')
# fi

# ===================
# Bash complete
# ===================
complete -F _fzf_path_completion cn cr
complete -f cn cr
complete gc


# ===================
# AWS
# ===================
export AWS_PROFILE=personal
