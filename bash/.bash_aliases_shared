# ===================
# Tmux
# ===================
tn() {
    tmux new-session -A -s "$1"
}

ta() {
    tmux attach -t "$1"
}

prune_tmux() {
    rm -rf ~/.tmux/resurrect/*
    rm -rf ~/.local/share/tmux-resurrect/*
}

# ==========================================
# Python Environment Loaders
# ==========================================
# Initialize Pyenv
load_pyenv() {
    export PYENV_ROOT="$HOME/.pyenv"
    command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"

    # eval "$(pyenv virtualenv-init -)"

    echo "Pyenv initialized - (path hijacked)"
}

# Initialize Miniforge Conda + Mamba
load_mamba() {
    # Conda
    __conda_setup="$('/home/rreji/miniforge3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__conda_setup"
    else
        if [ -f "/home/rreji/miniforge3/etc/profile.d/conda.sh" ]; then
            . "/home/rreji/miniforge3/etc/profile.d/conda.sh"
        else
            export PATH="/home/rreji/miniforge3/bin:$PATH"
        fi
    fi
    unset __conda_setup

    # Mamba
    export MAMBA_EXE='/home/rreji/miniforge3/bin/mamba';
    export MAMBA_ROOT_PREFIX='/home/rreji/miniforge3';
    __mamba_setup="$("$MAMBA_EXE" shell hook --shell bash --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__mamba_setup"
    else
        alias mamba="$MAMBA_EXE"
    fi
    unset __mamba_setup

    echo "Miniforge (Conda+Mamba) initialized - (path hijacked)"
}

# ===================
# Docker
# ===================
function clean_docker ()
{
   docker system prune -a -f
   docker kill $(docker ps -q)
   docker image prune -a -y
   sudo service docker restart
   sudo /etc/init.d/docker restart
}

# ===================
# AWS
# ===================
switch_aws() {
    if [ -z "$1" ]; then
        export AWS_PROFILE=personal
        echo "Switched to AWS profile: [personal]"
    else
        export AWS_PROFILE="$1"
        echo "Switched to AWS profile: [$1]"
    fi
}

# ===================
# Linters
# ===================
lint() {
	black "$1" --line-length=120  && pylint "$1"
}

validate_yaml() {
    python -c 'import yaml,sys;yaml.safe_load(sys.stdin)' < $1
}

